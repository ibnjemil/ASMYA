generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERIOR_AMIR
  VICE_AMIR
  SECRETARY
  EDUCATION_AMIR
  COMMUNITY_AMIR
  ADMIN_AMIR
  FINANCE_AMIR
  PROGRAM_AMIR
  SOCIAL_MEDIA_AMIR
  FOLLOWER
  TEACHER
  STUDENT
  PARENT
}

enum Side {
  MEN
  WOMEN
}

enum ChatType {
  NINE_AMIR
  THREE_MAIN
  SUB_AMIR_GROUP
  SMALL_AMIR_GROUP
  PUBLIC
  DIRECT
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  side      String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
}

model AiUsage {
  id             String   @id @default(cuid())
  userId         String
  query          String
  category       String
  language       String
  side           String
  responseTimeMs Int?
  createdAt      DateTime @default(now())
  User           User     @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  mediaUrl  String?
  createdBy String
  side      String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [createdBy], references: [id])
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime
  status    String
  notes     String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
}

model CashEntry {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  category    String
  description String?
  accountType String
  createdBy   String
  side        String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [createdBy], references: [id])
}

model Chat {
  id         String       @id @default(cuid())
  name       String
  type       String
  side       String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  ChatMember ChatMember[]
  Message    Message[]
}

model ChatMember {
  id       String   @id @default(cuid())
  chatId   String
  userId   String
  joinedAt DateTime @default(now())
  User     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Chat     Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model DailyActivityRecord {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime
  type      String
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, date, type])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  type      String
  content   String
  mediaUrl  String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  Chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Plan {
  id             String           @id @default(cuid())
  title          String
  description    String
  status         String           @default("PENDING")
  dueDate        DateTime
  reminderAt     DateTime?
  createdBy      String
  side           String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  User           User             @relation(fields: [createdBy], references: [id])
  PlanAssignment PlanAssignment[]
  Report         Report[]
}

model PlanAssignment {
  id        String   @id @default(cuid())
  planId    String
  userId    String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, userId])
}

model PublicComment {
  id         String     @id @default(cuid())
  postId     String
  content    String
  postedBy   String?
  createdAt  DateTime   @default(now())
  User       User?      @relation(fields: [postedBy], references: [id])
  PublicPost PublicPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PublicPost {
  id            String          @id @default(cuid())
  content       String
  mediaUrl      String?
  mediaType     String?
  postedBy      String?
  side          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  PublicComment PublicComment[]
  User          User?           @relation(fields: [postedBy], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        String   @id @default(cuid())
  title     String
  content   String
  planId    String?
  createdBy String
  side      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [createdBy], references: [id])
  Plan      Plan?    @relation(fields: [planId], references: [id])
}

model RevisionDebt {
  id         String    @id @default(cuid())
  studentId  String
  date       DateTime
  reason     String
  status     String    @default("PENDING")
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  User       User      @relation(fields: [studentId], references: [id])
}

model TestResult {
  id                              String   @id @default(cuid())
  studentId                       String
  teacherId                       String
  title                           String
  subject                         String?
  score                           Float
  maxScore                        Float
  imageUrl                        String?
  notes                           String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime
  User_TestResult_teacherIdToUser User     @relation("TestResult_teacherIdToUser", fields: [teacherId], references: [id])
  User_TestResult_studentIdToUser User     @relation("TestResult_studentIdToUser", fields: [studentId], references: [id])

  @@index([teacherId])
  @@index([studentId])
}

model User {
  id                                               String                @id @default(cuid())
  username                                         String                @unique
  password                                         String
  displayName                                      String
  avatarUrl                                        String?
  role                                             Role
  side                                             Side
  createdAt                                        DateTime              @default(now())
  updatedAt                                        DateTime
  subAmirId                                        String?
  ActivityLog                                      ActivityLog[]
  AiUsage                                          AiUsage[]
  Announcement                                     Announcement[]
  AttendanceRecord                                 AttendanceRecord[]
  CashEntry                                        CashEntry[]
  ChatMember                                       ChatMember[]
  DailyActivityRecord                              DailyActivityRecord[]
  Message                                          Message[]
  Plan                                             Plan[]
  PlanAssignment                                   PlanAssignment[]
  PublicComment                                    PublicComment[]
  PublicPost                                       PublicPost[]
  PushSubscription                                 PushSubscription[]
  Report                                           Report[]
  RevisionDebt                                     RevisionDebt[]
  TestResult_TestResult_teacherIdToUser            TestResult[]          @relation("TestResult_teacherIdToUser")
  TestResult_TestResult_studentIdToUser            TestResult[]          @relation("TestResult_studentIdToUser")
  User                                             User?                 @relation("UserToUser", fields: [subAmirId], references: [id])
  other_User                                       User[]                @relation("UserToUser")
  ParentProfile                                    ParentProfile?
  StudentProfileChildren                            StudentProfile[]       @relation("StudentParent")
  StudentProfile                                    StudentProfile?        @relation("StudentUser")
  TeacherProfile                                    TeacherProfile?
}

model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  @@map("parent_profiles")
}

model StudentProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  parentId  String?
  grade     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parent    User?   @relation("StudentParent", fields: [parentId], references: [id])
  user      User    @relation("StudentUser", fields: [userId], references: [id])
  @@map("student_profiles")
}

model SignupRequest {
  id         String   @id @default(cuid())
  username   String   @unique
  password   String
  displayName String
  role       String   // STUDENT or PARENT
  childUsername String? // if PARENT, which child they want to link
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  @@map("teacher_profiles")
}
